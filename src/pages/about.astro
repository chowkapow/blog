---
import Layout from '../components/Layout.astro';
import Prose from '../components/Prose.astro';
---

<Layout title="About" description="About this blog">
  <section class="about">
    <h1>About</h1>
    <Prose>
      <p>
        This is a quiet place to publish. No analytics, no comments, no
        newsletters — just writing.
      </p>
      <p>
        Built with <a href="https://astro.build">Astro</a>.
      </p>
    </Prose>
  </section>
</Layout>

<style>
  .about {
    max-width: var(--width-content);
    margin: 0 auto;
  }

  h1 {
    margin-bottom: var(--space-lg);
  }
</style>
